@page
@model OpinionHub.Web.Areas.Identity.Pages.Account.ConfirmEmailCodeModel
@{
    ViewData["Title"] = "Подтверждение почты";
}

<h1 class="mb-3">Подтверждение почты</h1>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">

        @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
        {
            <div class="alert alert-info">@Model.StatusMessage</div>
        }

        <div class="alert alert-secondary">
            Мы отправили 6‑значный код на <strong>@Model.EmailMasked</strong>.
            Введите его ниже.
        </div>

        <form method="post" class="card p-3">
            <input type="hidden" name="userId" value="@Model.UserId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.Code" class="form-label">Код подтверждения</label>
                <input asp-for="Input.Code" class="form-control" inputmode="numeric" autocomplete="one-time-code" />
                <span asp-validation-for="Input.Code" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Подтвердить</button>
        </form>

        <form method="post" asp-page-handler="Resend" class="mt-3">
            <input type="hidden" name="userId" value="@Model.UserId" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit" class="btn btn-outline-secondary w-100">Отправить код ещё раз</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
