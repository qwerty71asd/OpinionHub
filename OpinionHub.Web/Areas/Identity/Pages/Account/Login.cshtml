@page
@model OpinionHub.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h1 class="h4 text-center mb-3">@ViewData["Title"]</h1>

        <form id="account" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Login" class="form-label"></label>
                <input asp-for="Input.Login" class="form-control" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Login" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe"></label>
            </div>

            <button id="login-submit" type="submit" class="w-100 btn btn-primary">Войти</button>

            <div class="mt-3 d-flex justify-content-between flex-wrap gap-2">
                <a id="forgot-password" asp-page="./ForgotPassword">Забыли пароль?</a>
                <a asp-page="./ResendEmailConfirmation">Повторно отправить подтверждение</a>
            </div>

            <div class="mt-3 text-center">
                Нет аккаунта?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Зарегистрироваться</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

