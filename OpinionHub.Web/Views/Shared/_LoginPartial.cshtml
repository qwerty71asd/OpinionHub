@using Microsoft.AspNetCore.Identity
@using OpinionHub.Web.Models
@inject SignInManager<ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="d-flex align-items-center gap-3">
        <a asp-area="" asp-controller="Polls" asp-action="Profile" class="text-decoration-none text-dark fw-bold">
            <i class="bi bi-person-circle me-1"></i> @User.Identity?.Name
        </a>

        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
            <button type="submit" class="btn btn-outline-secondary btn-sm">Выйти</button>
        </form>
    </div>
}
else
{
    <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-sm">Войти</a>
    <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-sm">Регистрация</a>
}   