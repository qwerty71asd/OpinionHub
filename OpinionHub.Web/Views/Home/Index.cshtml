@model IEnumerable<OpinionHub.Web.Models.Poll>
@{
    ViewData["Title"] = "Главная";
}

<div class="container mt-5 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold">Активные опросы</h1>
        <a asp-controller="Polls" asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-lg"></i> Создать опрос
        </a>
    </div>

    <hr class="mb-5">

    @if (!Model.Any())
    {
        <div class="text-center py-5" id="no-polls-msg">
            <i class="bi bi-inboxes text-muted" style="font-size: 4rem;"></i>
            <p class="text-secondary fs-4 mt-3">Пока нет ни одного активного опроса.<br />Будьте первым!</p>
        </div>
    }
    else
    {
        <div class="poll-masonry" id="poll-feed-container">
            @foreach (var poll in Model)
            {
                <div class="card shadow-sm border-0 oh-card @(string.IsNullOrEmpty(poll.CoverImagePath) ? "border-top border-primary border-4" : "") overflow-hidden" id="poll-card-@poll.Id">

                    @if (!string.IsNullOrEmpty(poll.CoverImagePath))
                    {
                        <img src="@poll.CoverImagePath" class="card-img-top border-bottom border-primary border-4" style="height: 200px; object-fit: cover;" alt="Обложка">
                    }

                    <div class="card-body p-4 d-flex flex-column">
                        <h5 class="card-title fw-bold mb-3">@poll.Title</h5>

                        <div class="mt-auto">
                            <div class="d-flex align-items-center mb-3 text-secondary small">
                                <i class="bi bi-person-circle me-2"></i>
                                <span>Автор: @(poll.Author?.UserName ?? "Аноним")</span>
                            </div>

                            <a asp-controller="Polls" asp-action="Details" asp-route-id="@poll.Id"
                               class="btn btn-outline-primary w-100 fw-semibold">
                                Голосовать
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/poll-feed.js"></script>
}

<style>
    .poll-masonry {
        column-count: 1;
        column-gap: 1.5rem;
    }

    @@media (min-width: 768px) {
        .poll-masonry {
            column-count: 2;
        }
    }

    @@media (min-width: 992px) {
        .poll-masonry {
            column-count: 3;
        }
    }

    .poll-masonry .card {
        display: inline-block;
        width: 100%;
        margin-bottom: 1.5rem;
        break-inside: avoid;
    }

    .oh-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .oh-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>