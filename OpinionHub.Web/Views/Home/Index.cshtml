@model IReadOnlyCollection<OpinionHub.Web.Models.Poll>
@using OpinionHub.Web.Models
@{
    ViewData["Title"] = "Лента опросов";
    var active = Model.Count(p => p.Status == PollStatus.Active);
    var drafts = Model.Count(p => p.Status == PollStatus.Draft);
    var completed = Model.Count(p => p.Status == PollStatus.Completed);
}

<div class="oh-hero py-5 mb-4">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-7">
                <h1 class="display-5 fw-semibold mb-2">OpinionHub</h1>
                <p class="lead text-secondary mb-4">
                    Создавай опросы, собирай голоса и смотри результаты в реальном времени.
                </p>

                <div class="d-flex flex-wrap gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Polls" asp-action="Create" class="btn btn-primary btn-lg">Создать опрос</a>
                        <a href="#feed" class="btn btn-outline-secondary btn-lg">К ленте</a>
                    }
                    else
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">Регистрация</a>
                        <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary btn-lg">Войти</a>
                    }
                </div>
            </div>

            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="card border-0 shadow-sm oh-card">
                            <div class="card-body">
                                <div class="text-secondary small">Активные</div>
                                <div class="h3 mb-0">@active</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card border-0 shadow-sm oh-card">
                            <div class="card-body">
                                <div class="text-secondary small">Черновики</div>
                                <div class="h3 mb-0">@drafts</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="card border-0 shadow-sm oh-card">
                            <div class="card-body">
                                <div class="text-secondary small">Завершённые</div>
                                <div class="h3 mb-0">@completed</div>
                                <div class="small text-secondary">Всего опросов: <strong>@Model.Count</strong></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container pb-5" id="feed">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Лента</h2>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Polls" asp-action="Create" class="btn btn-sm btn-primary">+ Новый опрос</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm oh-card">
            <div class="card-body p-4">
                <div class="text-secondary">Пока нет ни одного опроса. Создай первый ✨</div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var poll in Model)
            {
                var badgeClass = poll.Status switch
                {
                    PollStatus.Active => "text-bg-success",
                    PollStatus.Draft => "text-bg-warning",
                    PollStatus.Completed => "text-bg-secondary",
                    PollStatus.Archived => "text-bg-dark",
                    _ => "text-bg-secondary"
                };

                <div class="col-12 col-md-6 col-lg-4">
                    <a class="text-decoration-none" asp-controller="Polls" asp-action="Details" asp-route-id="@poll.Id">
                        <div class="card border-0 shadow-sm oh-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <h3 class="h6 fw-semibold mb-2 text-body">@poll.Title</h3>
                                    <span class="badge @badgeClass">@poll.Status</span>
                                </div>

                                <div class="small text-secondary mb-3">
                                    Тип: <strong>@poll.PollType</strong>
                                    <span class="mx-1">•</span>
                                    Видимость: <strong>@poll.VisibilityType</strong>
                                    <span class="mx-1">•</span>
                                    Доступ: <strong>@(poll.AudienceType == AudienceType.Everyone ? "Все" : "Выбранные")</strong>
                                </div>

                                <div class="d-flex justify-content-between align-items-center small text-secondary">
                                    <span>Вариантов: <strong>@poll.Options.Count</strong></span>
                                    @if (poll.EndDateUtc is not null)
                                    {
                                        <span>До: <strong>@poll.EndDateUtc.Value.ToLocalTime().ToString("dd.MM HH:mm")</strong></span>
                                    }
                                    else
                                    {
                                        <span>Без дедлайна</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
