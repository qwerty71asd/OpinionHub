@model OpinionHub.Web.ViewModels.CreatePollViewModel
@{
    ViewData["Title"] = "Создание опроса";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" rel="stylesheet">

<div class="oh-hero py-4 py-md-5 mb-4">
    <div class="container">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h1 class="display-6 mb-1">Создание опроса</h1>
                <p class="text-secondary mb-0">Быстро набросай варианты и опубликуй, когда будешь готов.</p>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
                ← В ленту
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm oh-card">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Название</label>
                            <input asp-for="Title" class="form-control form-control-lg bg-body text-body" placeholder="Например: Где будем обедать?" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4 p-3 border rounded bg-body-tertiary">
                            <label class="form-label fw-bold">Заглавное фото (Обложка)</label>
                            <div class="form-text mb-2">Фото будет отображаться в ленте (формат 16:9).</div>

                            <label for="coverInput" id="coverInputLabel" class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center text-truncate border-2 border-dashed bg-body m-0" style="cursor: pointer; min-height: 55px;">
                                <i class="bi bi-image me-2 fs-5"></i> <span id="coverInputText" class="fw-medium">Выбрать файл обложки...</span>
                            </label>
                            <input type="file" asp-for="CoverImage" class="d-none" id="coverInput" accept="image/*" />

                            <div id="coverPreviewContainer" class="mt-3 d-none">
                                <img id="coverPreview" class="img-fluid rounded border shadow-sm mb-2" style="max-height: 250px; object-fit: cover; width: 100%;" />
                                <div id="aspectRatioWarning" class="alert alert-warning d-none mb-0">
                                    <i class="bi bi-exclamation-triangle"></i> Соотношение сторон этого фото отличается от 16:9.
                                    <div class="mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="moveToAttachments()">Сделать обычным вложением</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="PollType" class="form-label fw-bold">Тип голосования</label>
                                <select asp-for="PollType" class="form-select bg-body text-body" id="pollTypeSelect">
                                    <option value="SingleChoice">Один вариант</option>
                                    <option value="MultipleChoice">Несколько вариантов</option>
                                </select>
                                <div class="form-text text-primary mt-2" id="pollTypeHint" style="min-height: 40px;"></div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="VisibilityType" class="form-label fw-bold">Видимость голосов</label>
                                <select asp-for="VisibilityType" class="form-select bg-body text-body" id="visibilitySelect">
                                    <option value="Public">Открытое голосование</option>
                                    <option value="Anonymous">Анонимное голосование</option>
                                </select>
                                <div class="form-text text-primary mt-2" id="visibilityHint" style="min-height: 40px;"></div>
                            </div>
                        </div>

                        <div class="mt-4">
                            <label asp-for="AudienceType" class="form-label fw-bold">Доступ к опросу</label>
                            <select asp-for="AudienceType" class="form-select bg-body text-body" id="audienceSelect">
                                <option value="Everyone">Все пользователи</option>
                                <option value="SelectedUsers">Только выбранные пользователи</option>
                            </select>
                            <div class="form-text text-primary mt-2" id="audienceHint"></div>
                        </div>

                        <div id="audienceUsersBox" class="mt-3 border rounded-3 p-3 bg-body shadow-sm d-none">
                            <label class="form-label fw-bold">Пригласить участников</label>
                            <input type="text" class="form-control bg-body text-body" id="userSearch" placeholder="Начни вводить логин…" autocomplete="off" />
                            <div class="list-group mt-2 shadow-sm position-absolute z-3 w-100" id="userResults" style="max-height: 220px; overflow:auto; max-width: 90%;"></div>

                            <div id="selectedUsers" class="mt-3 d-flex flex-wrap gap-2"></div>
                            <div id="audienceValidation" class="text-danger small mt-2 d-none">Добавь хотя бы одного пользователя.</div>
                        </div>

                        <div class="row g-4 mt-2 p-3 border rounded bg-body-tertiary align-items-start">
                            <div class="col-md-7">
                                <label class="form-label fw-bold">Срок проведения</label>
                                <select class="form-select border-secondary bg-body text-body" id="quickDateSelect">
                                    <option value="tomorrow">До завтра</option>
                                    <option value="week" selected>1 неделя</option>
                                    <option value="month">1 месяц (максимум)</option>
                                    <option value="custom">Указать точную дату и время...</option>
                                </select>

                                <div id="customDateContainer" class="mt-2 d-none">
                                    <input asp-for="EndDateUtc" class="form-control border-primary bg-body text-body" type="datetime-local" id="customDateInput" />
                                    <div class="form-text text-danger d-none" id="dateError">Дата не может быть больше, чем через месяц!</div>
                                </div>

                                <div class="form-text mt-2 fs-6" id="dateHint"></div>
                            </div>
                            <div class="col-md-5 pt-4">
                                <div class="form-check form-switch fs-5">
                                    <input class="form-check-input" type="checkbox" asp-for="CanChangeVote" id="canChangeVoteSwitch">
                                    <label class="form-check-label fs-6 ms-2 text-body" for="canChangeVoteSwitch">Разрешить менять голос</label>
                                </div>
                                <div class="form-text mt-1 text-muted">Пользователи смогут переголосовать до окончания.</div>
                            </div>
                        </div>

                        <hr class="my-5" />

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0 fw-bold">Варианты ответа</h5>
                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold" id="addOptionBtn">+ Добавить</button>
                        </div>

                        <div id="optionsList" class="vstack gap-3">
                            @for (var i = 0; i < Model.Options.Count; i++)
                            {
                                <div class="input-group align-items-stretch shadow-sm rounded">
                                    <span class="input-group-text bg-body-tertiary fw-bold text-secondary border-end-0">@(i + 1)</span>
                                    <input name="Options[@i].Text" class="form-control border-start-0 border-end-0 ps-0 bg-body text-body" value="@Model.Options[i].Text" placeholder="Текст варианта..." required />

                                    <label for="optionImage_@i" class="input-group-text bg-body text-secondary border-start-0 mb-0 px-3 d-flex align-items-center justify-content-center option-image-label" style="cursor: pointer; width: 54px; overflow: hidden; padding: 0 !important;" title="Прикрепить фото">
                                        <i class="bi bi-paperclip fs-5 option-icon"></i>
                                        <img class="option-preview d-none" style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px;" />
                                    </label>
                                    <input type="file" name="Options[@i].Image" id="optionImage_@i" class="d-none option-image-input" accept="image/*" />

                                    <button type="button" class="btn btn-danger remove-option px-3" title="Удалить"><i class="bi bi-trash"></i></button>
                                </div>
                            }
                        </div>

                        <hr class="my-5" />

                        <div class="mb-4">
                            <label asp-for="AttachedFiles" class="form-label fw-bold">Дополнительные файлы</label>
                            <input type="file" asp-for="AttachedFiles" class="form-control bg-body text-body" multiple id="attachmentInput" />
                            <div class="form-text">Документы, схемы или референсы. Они будут доступны для скачивания внутри опроса.</div>
                        </div>

                        <div class="d-flex flex-column flex-md-row justify-content-end gap-3 mt-5">
                            <button type="submit" class="btn btn-light border px-4" name="PublishNow" value="false">
                                Сохранить черновик
                            </button>
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow" name="PublishNow" value="true">
                                Опубликовать сейчас
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-body text-body">
            <div class="modal-header border-bottom border-secondary">
                <h5 class="modal-title fw-bold">Кадрирование обложки</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
            </div>
            <div class="modal-body text-center bg-body-tertiary">
                <div class="img-container" style="max-height: 60vh; overflow: hidden;">
                    <img id="imageToCrop" src="" style="max-width: 100%; display: block;">
                </div>
            </div>
            <div class="modal-footer border-top border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Отмена</button>
                <button type="button" class="btn btn-primary px-4 fw-bold" id="cropBtn">Применить</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <script>
        // --- 1. ЛОГИКА ДИНАМИЧЕСКИХ ХИНТОВ ---
        (function () {
            const hints = {
                pollType: {
                    'SingleChoice': '<i class="bi bi-info-circle text-primary"></i> Участники смогут выбрать строго <b>один</b> вариант ответа.',
                    'MultipleChoice': '<i class="bi bi-info-circle text-primary"></i> Участники смогут выбрать <b>несколько</b> вариантов одновременно.'
                },
                visibility: {
                    'Public': '<i class="bi bi-eye text-primary"></i> Все будут видеть, кто именно и за какой вариант проголосовал.',
                    'Anonymous': '<i class="bi bi-incognito text-primary"></i> Голоса учтутся, но никто (даже вы) не узнает авторов голосов.'
                },
                audience: {
                    'Everyone': '<i class="bi bi-globe text-primary"></i> Опрос будет виден в общей ленте. Голосовать смогут все.',
                    'SelectedUsers': '<i class="bi bi-lock text-primary"></i> Опрос скрыт из ленты. Доступ только по приглашениям.'
                }
            };

            function updateHint(selectId, hintId, hintDictionary) {
                const select = document.getElementById(selectId);
                const hint = document.getElementById(hintId);
                const update = () => {
                    hint.style.opacity = 0;
                    setTimeout(() => {
                        hint.innerHTML = hintDictionary[select.value] || '';
                        hint.style.opacity = 1;
                        hint.style.transition = "opacity 0.3s ease";
                    }, 150);
                };
                select.addEventListener('change', update);
                update();
            }

            updateHint('pollTypeSelect', 'pollTypeHint', hints.pollType);
            updateHint('visibilitySelect', 'visibilityHint', hints.visibility);
            updateHint('audienceSelect', 'audienceHint', hints.audience);
        })();

        // --- 2. ЛОГИКА УМНОЙ ДАТЫ ---
        (function () {
            const quickDate = document.getElementById('quickDateSelect');
            const customDateContainer = document.getElementById('customDateContainer');
            const customDateInput = document.getElementById('customDateInput');
            const dateError = document.getElementById('dateError');
            const dateHint = document.getElementById('dateHint');

            function formatForInput(d) {
                const pad = n => n.toString().padStart(2, '0');
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            function updateDateHint() {
                if (customDateInput.value) {
                    const d = new Date(customDateInput.value);
                    const formatted = d.toLocaleString('ru-RU', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
                    dateHint.innerHTML = `<i class="bi bi-clock-history"></i> Завершится: <b class="text-body">${formatted}</b>`;
                    dateHint.className = "form-text text-success mt-2 fs-6";
                }
            }

            const now = new Date();
            const maxDate = new Date();
            maxDate.setMonth(maxDate.getMonth() + 1);

            customDateInput.min = formatForInput(now);
            customDateInput.max = formatForInput(maxDate);

            if (!customDateInput.value) {
                let targetDate = new Date();
                targetDate.setDate(targetDate.getDate() + 7);
                customDateInput.value = formatForInput(targetDate);
                quickDate.value = 'week';
            } else {
                quickDate.value = 'custom';
                customDateContainer.classList.remove('d-none');
            }

            quickDate.addEventListener('change', function () {
                let targetDate = new Date();
                customDateContainer.classList.add('d-none');
                dateError.classList.add('d-none');

                if (this.value === 'tomorrow') {
                    targetDate.setDate(targetDate.getDate() + 1);
                    customDateInput.value = formatForInput(targetDate);
                }
                else if (this.value === 'week') {
                    targetDate.setDate(targetDate.getDate() + 7);
                    customDateInput.value = formatForInput(targetDate);
                }
                else if (this.value === 'month') {
                    customDateInput.value = formatForInput(maxDate);
                }
                else if (this.value === 'custom') {
                    customDateContainer.classList.remove('d-none');
                }
                updateDateHint();
            });

            customDateInput.addEventListener('change', function () {
                const selected = new Date(this.value);
                if (selected > maxDate) {
                    this.classList.add('is-invalid');
                    dateError.classList.remove('d-none');
                    this.value = formatForInput(maxDate);
                    setTimeout(() => {
                        this.classList.remove('is-invalid');
                        dateError.classList.add('d-none');
                    }, 3000);
                }
                updateDateHint();
            });

            updateDateHint();
        })();

        // --- 3. СКРИПТ ВАРИАНТОВ ОТВЕТА (Минниатюры) ---
        (function () {
            const list = document.getElementById('optionsList');
            const addBtn = document.getElementById('addOptionBtn');

            function renumber() {
                const groups = list.querySelectorAll('.input-group');
                groups.forEach((g, idx) => {
                    const badge = g.querySelector('.input-group-text');
                    if (badge) badge.textContent = String(idx + 1);

                    const textInput = g.querySelector('input[type="text"]') || g.querySelector('input:not([type="file"])');
                    if (textInput) textInput.name = `Options[${idx}].Text`;

                    const fileInput = g.querySelector('input[type="file"]');
                    if (fileInput) fileInput.name = `Options[${idx}].Image`;

                    const label = g.querySelector('.option-image-label');
                    if (label && fileInput) {
                        fileInput.id = `optionImage_${idx}`;
                        label.setAttribute('for', `optionImage_${idx}`);
                    }
                });
            }

            list.addEventListener('click', (e) => {
                const btn = e.target.closest('.remove-option');
                if (!btn) return;
                const group = btn.closest('.input-group');
                if (!group) return;
                group.remove();
                if (list.querySelectorAll('.input-group').length < 2) {
                    addOption('');
                }
                renumber();
            });

            list.addEventListener('change', (e) => {
                if (e.target.classList.contains('option-image-input')) {
                    const label = e.target.previousElementSibling;
                    const icon = label.querySelector('.option-icon');
                    const preview = label.querySelector('.option-preview');

                    const file = e.target.files[0];
                    if (file) {
                        const url = URL.createObjectURL(file);
                        preview.src = url;
                        preview.classList.remove('d-none');
                        icon.classList.add('d-none');
                        label.classList.remove('px-3');
                    } else {
                        preview.src = '';
                        preview.classList.add('d-none');
                        icon.classList.remove('d-none');
                        label.classList.add('px-3');
                    }
                }
            });

            function addOption(value) {
                const idx = list.querySelectorAll('.input-group').length;
                const wrap = document.createElement('div');
                wrap.className = 'input-group align-items-stretch shadow-sm rounded mb-3';
                wrap.innerHTML = `
                            <span class="input-group-text bg-body-tertiary fw-bold text-secondary border-end-0">${idx + 1}</span>
                            <input name="Options[${idx}].Text" class="form-control border-start-0 border-end-0 ps-0 bg-body text-body" placeholder="Текст варианта..." required />

                            <label for="optionImage_${idx}" class="input-group-text bg-body text-secondary border-start-0 mb-0 px-3 d-flex align-items-center justify-content-center option-image-label" style="cursor: pointer; width: 54px; overflow: hidden; padding: 0 !important;" title="Прикрепить фото">
                                <i class="bi bi-paperclip fs-5 option-icon"></i>
                                <img class="option-preview d-none" style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px;" />
                            </label>
                            <input type="file" name="Options[${idx}].Image" id="optionImage_${idx}" class="d-none option-image-input" accept="image/*" />

                            <button type="button" class="btn btn-danger remove-option px-3" title="Удалить"><i class="bi bi-trash"></i></button>
                        `;
                list.appendChild(wrap);
            }

            addBtn.addEventListener('click', () => {
                addOption('');
                renumber();
            });
        })();

        // --- 4. СКРИПТ CROPPER.JS ДЛЯ ОБЛОЖКИ ---
        (function () {
            const coverInput = document.getElementById('coverInput');
            const coverInputText = document.getElementById('coverInputText');
            const previewContainer = document.getElementById('coverPreviewContainer');
            const previewImage = document.getElementById('coverPreview');
            const warning = document.getElementById('aspectRatioWarning');

            let cropper;
            const cropModalElement = document.getElementById('cropModal');
            const cropModal = new bootstrap.Modal(cropModalElement);
            const imageToCrop = document.getElementById('imageToCrop');
            let currentFileName = "cover.jpg";

            // Открываем модалку при выборе файла
            coverInput.addEventListener('change', function (e) {
                const files = e.target.files;
                if (files && files.length > 0) {
                    const file = files[0];
                    currentFileName = file.name;
                    const url = URL.createObjectURL(file);
                    imageToCrop.src = url;
                    cropModal.show();
                } else {
                    previewContainer.classList.add('d-none');
                    coverInputText.textContent = 'Выбрать файл обложки...';
                }
            });

            // Инициализация Cropper при открытии модалки
            cropModalElement.addEventListener('shown.bs.modal', function () {
                cropper = new Cropper(imageToCrop, {
                    aspectRatio: 16 / 9, // Жестко 16:9
                    viewMode: 2,         // Ограничиваем рамку размерами картинки
                    autoCropArea: 1,     // Рамка сразу на максимум
                });
            });

            // Очистка при закрытии модалки
            cropModalElement.addEventListener('hidden.bs.modal', function () {
                if (cropper) {
                    cropper.destroy();
                    cropper = null;
                }
                // Если превью не обновилось (нажали отмену), сбрасываем инпут
                if (previewContainer.classList.contains('d-none')) {
                    coverInput.value = '';
                }
            });

            // Обработка кнопки "Применить"
            document.getElementById('cropBtn').addEventListener('click', function () {
                if (!cropper) return;

                // Получаем обрезанный канвас
                const canvas = cropper.getCroppedCanvas({
                    width: 1280, // Оптимизируем размер для базы/папки
                    height: 720,
                    imageSmoothingEnabled: true,
                    imageSmoothingQuality: 'high',
                });

                // Превращаем канвас в Blob (файл)
                canvas.toBlob(function (blob) {
                    const croppedFile = new File([blob], currentFileName, {
                        type: 'image/jpeg',
                        lastModified: Date.now()
                    });

                    // Создаем DataTransfer для подмены файла в инпуте
                    const dt = new DataTransfer();
                    dt.items.add(croppedFile);
                    coverInput.files = dt.files;

                    // Обновляем превью на странице
                    const croppedUrl = URL.createObjectURL(croppedFile);
                    previewImage.src = croppedUrl;
                    previewContainer.classList.remove('d-none');
                    coverInputText.textContent = currentFileName + " (Обрезано 16:9)";

                    warning.classList.add('d-none'); // Прячем ворнинг навсегда

                    cropModal.hide(); // Закрываем модалку
                }, 'image/jpeg', 0.9);
            });
        })();

        window.moveToAttachments = function () {
            const coverInput = document.getElementById('coverInput');
            const coverInputText = document.getElementById('coverInputText');
            const attachmentInput = document.getElementById('attachmentInput');
            const dt = new DataTransfer();

            for (let i = 0; i < attachmentInput.files.length; i++) {
                dt.items.add(attachmentInput.files[i]);
            }
            if (coverInput.files.length > 0) {
                dt.items.add(coverInput.files[0]);
            }

            attachmentInput.files = dt.files;
            coverInput.value = '';
            coverInputText.textContent = 'Выбрать файл обложки...';
            document.getElementById('coverPreviewContainer').classList.add('d-none');
            attachmentInput.classList.add('is-valid');
            setTimeout(() => attachmentInput.classList.remove('is-valid'), 2000);
        };

        // --- 5. СКРИПТ ПОЛЬЗОВАТЕЛЕЙ ---
        (function () {
            const audienceSelect = document.getElementById('audienceSelect');
            const box = document.getElementById('audienceUsersBox');
            const search = document.getElementById('userSearch');
            const results = document.getElementById('userResults');
            const selected = document.getElementById('selectedUsers');
            const validation = document.getElementById('audienceValidation');
            const selectedIds = new Set();
            function setBoxVisibility() {
                const isSelected = audienceSelect.value === 'SelectedUsers';
                box.classList.toggle('d-none', !isSelected);
                if (!isSelected) { validation.classList.add('d-none'); }
            }
            function clearResults() { results.innerHTML = ''; }
            function renderResults(items) {
                clearResults();
                if (!items || items.length === 0) return;
                for (const u of items) {
                    const a = document.createElement('button');
                    a.type = 'button';
                    a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-body text-body';
                    a.innerHTML = `<span>${escapeHtml(u.userName)}</span><span class="badge text-bg-secondary">добавить</span>`;
                    a.addEventListener('click', () => addUser(u.id, u.userName));
                    results.appendChild(a);
                }
            }
            function addUser(id, userName) {
                if (selectedIds.has(id)) return;
                selectedIds.add(id);
                const chip = document.createElement('span');
                chip.className = 'badge rounded-pill text-bg-primary d-inline-flex align-items-center gap-2 me-1 mb-1';
                chip.dataset.userId = id;
                chip.innerHTML = `${escapeHtml(userName)} <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Удалить"></button>`;
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'AllowedUserIds';
                hidden.value = id;
                chip.appendChild(hidden);
                chip.querySelector('button')?.addEventListener('click', () => {
                    selectedIds.delete(id);
                    chip.remove();
                });
                selected.appendChild(chip);
                validation.classList.add('d-none');
                clearResults();
                search.value = '';
                search.focus();
            }
            function escapeHtml(str) {
                return String(str ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
            }
            let abort = null;
            let t = null;
            search?.addEventListener('input', () => {
                const q = (search.value || '').trim();
                if (t) clearTimeout(t);
                t = setTimeout(async () => {
                    if (q.length < 2) { clearResults(); return; }
                    try {
                        abort?.abort();
                        abort = new AbortController();
                        const resp = await fetch(`/api/users/search?q=${encodeURIComponent(q)}`, { signal: abort.signal });
                        if (!resp.ok) return;
                        const data = await resp.json();
                        const filtered = (data || []).filter(x => !selectedIds.has(x.id));
                        renderResults(filtered);
                    } catch { }
                }, 200);
            });
            document.querySelector('form')?.addEventListener('submit', (e) => {
                if (audienceSelect.value === 'SelectedUsers' && selectedIds.size === 0) {
                    validation.classList.remove('d-none');
                    e.preventDefault();
                    search.focus();
                }
            });
            audienceSelect?.addEventListener('change', setBoxVisibility);
            setBoxVisibility();
        })();
    </script>
}