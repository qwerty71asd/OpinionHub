@model OpinionHub.Web.ViewModels.CreatePollViewModel
@{
    ViewData["Title"] = "Создание опроса";
}

<div class="oh-hero py-4 py-md-5 mb-4">
    <div class="container">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h1 class="display-6 mb-1">Создание опроса</h1>
                <p class="text-secondary mb-0">Быстро набросай варианты и опубликуй, когда будешь готов.</p>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">
                ← В ленту
            </a>
        </div>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm oh-card">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                        }

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-bold">Название</label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Например: Где будем обедать?" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-4 p-3 border rounded bg-body-tertiary">
                            <label class="form-label fw-bold">Заглавное фото (Обложка)</label>
                            <div class="form-text mb-2">Рекомендуемое соотношение 16:9. Фото будет отображаться в ленте.</div>
                            <input type="file" asp-for="CoverImage" class="form-control" id="coverInput" accept="image/*" />

                            <div id="coverPreviewContainer" class="mt-3 d-none">
                                <img id="coverPreview" class="img-fluid rounded border shadow-sm mb-2" style="max-height: 250px; object-fit: cover; width: 100%;" />
                                <div id="aspectRatioWarning" class="alert alert-warning d-none mb-0">
                                    <i class="bi bi-exclamation-triangle"></i> Соотношение сторон этого фото отличается от 16:9. В ленте оно может выглядеть обрезанным.
                                    <div class="mt-2">
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="moveToAttachments()">Сделать обычным вложением</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="PollType" class="form-label">Тип голосования</label>
                                <select asp-for="PollType" asp-items="Html.GetEnumSelectList<OpinionHub.Web.Models.PollType>()" class="form-select"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="VisibilityType" class="form-label">Видимость</label>
                                <select asp-for="VisibilityType" asp-items="Html.GetEnumSelectList<OpinionHub.Web.Models.VisibilityType>()" class="form-select"></select>
                                <div class="form-text">Anonymous скрывает, кто как проголосовал.</div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label asp-for="AudienceType" class="form-label">Кто может голосовать</label>
                            <select asp-for="AudienceType" class="form-select" id="audienceSelect">
                                <option value="Everyone">Все пользователи</option>
                                <option value="SelectedUsers">Только выбранные пользователи</option>
                            </select>
                            <div class="form-text">Для "Только выбранные" добавь участников через поиск.</div>
                        </div>

                        <div id="audienceUsersBox" class="mt-3 border rounded-3 p-3 bg-body-tertiary d-none">
                            <label class="form-label">Участники</label>
                            <input type="text" class="form-control" id="userSearch" placeholder="Начни вводить имя пользователя…" autocomplete="off" />
                            <div class="list-group mt-2" id="userResults" style="max-height: 220px; overflow:auto;"></div>

                            <div id="selectedUsers" class="mt-3 d-flex flex-wrap gap-2"></div>
                            <div id="audienceValidation" class="text-danger small mt-2 d-none">Добавь хотя бы одного пользователя.</div>
                        </div>

                        <div class="row g-3 mt-0">
                            <div class="col-md-6">
                                <label asp-for="EndDateUtc" class="form-label">Дата окончания</label>
                                <input asp-for="EndDateUtc" class="form-control" type="datetime-local" />
                                <div class="form-text">Вводится в <strong>местном времени</strong>, хранится в UTC.</div>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="CanChangeVote" class="form-check-input" />
                                    <label asp-for="CanChangeVote" class="form-check-label">Разрешить менять голос</label>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5 class="mb-0 fw-bold">Варианты ответа</h5>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="addOptionBtn">+ Добавить</button>
                        </div>

                        <div id="optionsList" class="vstack gap-3">
                            @for (var i = 0; i < Model.Options.Count; i++)
                            {
                                <div class="input-group align-items-center">
                                    <span class="input-group-text">@(i + 1)</span>
                                    <input name="Options[@i].Text" class="form-control" value="@Model.Options[i].Text" placeholder="Текст варианта" />
                                    <input type="file" name="Options[@i].Image" class="form-control" accept="image/*" style="max-width: 220px;" title="Фото варианта" />
                                    <button type="button" class="btn btn-outline-danger remove-option" title="Удалить">✕</button>
                                </div>
                            }
                        </div>

                        <hr class="my-4" />

                        <div class="mb-4 p-3 border rounded">
                            <label asp-for="AttachedFiles" class="form-label fw-bold">Дополнительные файлы</label>
                            <input type="file" asp-for="AttachedFiles" class="form-control" multiple id="attachmentInput" />
                            <div class="form-text">Можно выбрать несколько файлов. Они будут доступны для скачивания внутри опроса.</div>
                        </div>

                        <div class="d-flex flex-column flex-md-row justify-content-end gap-2 mt-4">
                            <button type="submit" class="btn btn-outline-secondary" name="PublishNow" value="false">
                                Сохранить как черновик
                            </button>
                            <button type="submit" class="btn btn-primary px-4" name="PublishNow" value="true">
                                Опубликовать
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Скрипт для вариантов ответа (Твой, но слегка обновленный для файлов)
        (function () {
            const list = document.getElementById('optionsList');
            const addBtn = document.getElementById('addOptionBtn');

            function renumber() {
                const groups = list.querySelectorAll('.input-group');
                groups.forEach((g, idx) => {
                    const badge = g.querySelector('.input-group-text');
                    if (badge) badge.textContent = String(idx + 1);

                    // Обновляем имена инпутов
                    const textInput = g.querySelector('input[type="text"]') || g.querySelector('input:not([type="file"])');
                    if (textInput) textInput.name = `Options[${idx}].Text`;

                    const fileInput = g.querySelector('input[type="file"]');
                    if (fileInput) fileInput.name = `Options[${idx}].Image`;
                });
            }

            list.addEventListener('click', (e) => {
                const btn = e.target.closest('.remove-option');
                if (!btn) return;
                const group = btn.closest('.input-group');
                if (!group) return;
                group.remove();
                if (list.querySelectorAll('.input-group').length < 2) {
                    addOption('');
                }
                renumber();
            });

            function addOption(value) {
                const idx = list.querySelectorAll('.input-group').length;
                const wrap = document.createElement('div');
                wrap.className = 'input-group align-items-center';
                wrap.innerHTML = `
                            <span class="input-group-text">${idx + 1}</span>
                            <input name="Options[${idx}].Text" class="form-control" placeholder="Текст варианта" value="${(value ?? '').replace(/"/g, '&quot;')}" />
                            <input type="file" name="Options[${idx}].Image" class="form-control" accept="image/*" style="max-width: 220px;" title="Фото варианта" />
                            <button type="button" class="btn btn-outline-danger remove-option" title="Удалить">✕</button>
                        `;
                list.appendChild(wrap);
            }

            addBtn.addEventListener('click', () => {
                addOption('');
                renumber();
            });
        })();

        // Скрипт проверки соотношения сторон обложки (Новый)
        (function () {
            const coverInput = document.getElementById('coverInput');
            const previewContainer = document.getElementById('coverPreviewContainer');
            const previewImage = document.getElementById('coverPreview');
            const warning = document.getElementById('aspectRatioWarning');

            coverInput.addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) {
                    previewContainer.classList.add('d-none');
                    return;
                }

                const url = URL.createObjectURL(file);
                previewImage.src = url;
                previewContainer.classList.remove('d-none');

                previewImage.onload = function () {
                    const ratio = this.naturalWidth / this.naturalHeight;
                    const targetRatio = 16 / 9; // ~1.77

                    // Если отклонение больше 10% от 16:9, показываем предупреждение
                    if (Math.abs(ratio - targetRatio) > 0.17) {
                        warning.classList.remove('d-none');
                    } else {
                        warning.classList.add('d-none');
                    }
                }
            });
        })();

        // Функция переноса обложки во вложения (вызывается из предупреждения)
        window.moveToAttachments = function () {
            const coverInput = document.getElementById('coverInput');
            const attachmentInput = document.getElementById('attachmentInput');

            // Имитация переноса: DataTransfer API позволяет программно задавать файлы
            const dt = new DataTransfer();

            // Копируем существующие вложения
            for (let i = 0; i < attachmentInput.files.length; i++) {
                dt.items.add(attachmentInput.files[i]);
            }
            // Добавляем обложку
            if (coverInput.files.length > 0) {
                dt.items.add(coverInput.files[0]);
            }

            attachmentInput.files = dt.files;
            coverInput.value = ''; // Очищаем обложку
            document.getElementById('coverPreviewContainer').classList.add('d-none');

            // Подсветка поля вложений, чтобы юзер понял, что произошло
            attachmentInput.classList.add('is-valid');
            setTimeout(() => attachmentInput.classList.remove('is-valid'), 2000);
        };

        // Твой оригинальный скрипт для поиска пользователей
        (function () {
            const audienceSelect = document.getElementById('audienceSelect');
            const box = document.getElementById('audienceUsersBox');
            const search = document.getElementById('userSearch');
            const results = document.getElementById('userResults');
            const selected = document.getElementById('selectedUsers');
            const validation = document.getElementById('audienceValidation');

            const selectedIds = new Set();

            function setBoxVisibility() {
                const isSelected = audienceSelect.value === 'SelectedUsers';
                box.classList.toggle('d-none', !isSelected);
                if (!isSelected) {
                    validation.classList.add('d-none');
                }
            }

            function clearResults() {
                results.innerHTML = '';
            }

            function renderResults(items) {
                clearResults();
                if (!items || items.length === 0) return;
                for (const u of items) {
                    const a = document.createElement('button');
                    a.type = 'button';
                    a.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
                    a.innerHTML = `<span>${escapeHtml(u.userName)}</span><span class="badge text-bg-secondary">добавить</span>`;
                    a.addEventListener('click', () => addUser(u.id, u.userName));
                    results.appendChild(a);
                }
            }

            function addUser(id, userName) {
                if (selectedIds.has(id)) return;
                selectedIds.add(id);

                const chip = document.createElement('span');
                chip.className = 'badge rounded-pill text-bg-primary d-inline-flex align-items-center gap-2 me-1 mb-1';
                chip.dataset.userId = id;
                chip.innerHTML = `${escapeHtml(userName)} <button type="button" class="btn-close btn-close-white btn-sm" aria-label="Удалить"></button>`;

                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'AllowedUserIds';
                hidden.value = id;
                chip.appendChild(hidden);

                chip.querySelector('button')?.addEventListener('click', () => {
                    selectedIds.delete(id);
                    chip.remove();
                });

                selected.appendChild(chip);
                validation.classList.add('d-none');
                clearResults();
                search.value = '';
                search.focus();
            }

            function escapeHtml(str) {
                return String(str ?? '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            let abort = null;
            let t = null;
            search?.addEventListener('input', () => {
                const q = (search.value || '').trim();
                if (t) clearTimeout(t);
                t = setTimeout(async () => {
                    if (q.length < 2) {
                        clearResults();
                        return;
                    }

                    try {
                        abort?.abort();
                        abort = new AbortController();
                        const resp = await fetch(`/api/users/search?q=${encodeURIComponent(q)}`, { signal: abort.signal });
                        if (!resp.ok) return;
                        const data = await resp.json();
                        const filtered = (data || []).filter(x => !selectedIds.has(x.id));
                        renderResults(filtered);
                    } catch { }
                }, 200);
            });

            document.querySelector('form')?.addEventListener('submit', (e) => {
                if (audienceSelect.value === 'SelectedUsers' && selectedIds.size === 0) {
                    validation.classList.remove('d-none');
                    e.preventDefault();
                    search.focus();
                }
            });

            audienceSelect?.addEventListener('change', setBoxVisibility);
            setBoxVisibility();
        })();
    </script>
}