@using System.Security.Claims
@using OpinionHub.Web.Models
@model OpinionHub.Web.Models.Poll
@{
    ViewData["Title"] = Model.Title;
    var total = Model.Votes.Count;
    var myId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var isAuthor = User.Identity?.IsAuthenticated == true && myId == Model.AuthorId;
    var isEmailConfirmed = (ViewBag.IsEmailConfirmed as bool?) ?? false;
    var returnUrl = Url.Action("Details", "Polls", new { id = Model.Id });
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="oh-hero py-4 py-md-5 mb-4">
    <div class="container">
        @if (TempData["EmailConfirmRequired"] is string emailConfirmMsg)
        {
            <div class="alert alert-warning mb-3">@emailConfirmMsg</div>
        }

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <h1 class="display-6 mb-0">@Model.Title</h1>

                    <span class="badge rounded-pill @(
                        Model.Status == PollStatus.Active ? "text-bg-success" :
                        Model.Status == PollStatus.Draft ? "text-bg-warning" :
                        Model.Status == PollStatus.Completed ? "text-bg-secondary" : "text-bg-dark")">
                        @Model.Status
                    </span>
                </div>

                <div class="text-secondary">
                    Тип: <strong>@Model.PollType</strong>
                    <span class="mx-1">•</span>
                    Видимость: <strong>@Model.VisibilityType</strong>
                    <span class="mx-1">•</span>
                    Доступ: <strong>@(Model.AudienceType == AudienceType.Everyone ? "Все" : "Выбранные")</strong>
                    <span class="mx-1">•</span>
                    Голосов: <strong>@total</strong>
                    @if (Model.EndDateUtc is not null)
                    {
                        <span class="mx-1">•</span>
                        <span>До: <strong>@Model.EndDateUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong></span>
                    }
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">← В ленту</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary" asp-action="Create">+ Создать опрос</a>
                }
            </div>
        </div>
    </div>
</div>

<div class="container pb-5">
    @if (TempData["VoteError"] is string voteError)
    {
        <div class="alert alert-danger shadow-sm">@voteError</div>
    }

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm oh-card h-100 overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.CoverImagePath))
                {
                    <img src="@Model.CoverImagePath" class="card-img-top" style="height: 220px; object-fit: cover;" alt="Обложка опроса" />
                }

                <div class="card-body p-4">
                    <h2 class="h5 mb-4 fw-bold">Голосование</h2>

                    @if (Model.Status != PollStatus.Active)
                    {
                        <div class="alert alert-secondary">Опрос не активен — голосование недоступно.</div>
                    }
                    else if (User.Identity?.IsAuthenticated != true)
                    {
                        <div class="alert alert-light border mb-3">Чтобы проголосовать, нужно войти в систему.</div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Login">Войти</a>
                            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
                        </div>
                    }
                    else
                    {
                        @if (!isEmailConfirmed)
                        {
                            <div class="alert alert-warning">
                                Чтобы голосовать, нужно подтвердить почту.
                                <a class="ms-2 fw-bold" asp-area="Identity" asp-page="/Account/ConfirmEmailCode" asp-route-userId="@myId" asp-route-returnUrl="@returnUrl">Подтвердить</a>
                            </div>
                        }
                        else
                        {
                            <form asp-action="Vote" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />

                                <div class="vstack gap-3">
                                    @foreach (var option in Model.Options)
                                    {
                                        <div class="form-check d-flex align-items-center p-2 border rounded hover-bg-light transition">
                                            <input class="form-check-input ms-1 me-3"
                                                   type="@(Model.PollType == PollType.SingleChoice ? "radio" : "checkbox")"
                                                   name="optionIds"
                                                   value="@option.Id"
                                                   id="opt-@option.Id" style="transform: scale(1.2);" />

                                            <label class="form-check-label d-flex align-items-center w-100" for="opt-@option.Id" style="cursor:pointer;">
                                                @if (!string.IsNullOrEmpty(option.ImagePath))
                                                {
                                                    <img src="@option.ImagePath" class="rounded me-3 border" style="width: 50px; height: 50px; object-fit: cover;" alt="Фото варианта" />
                                                }
                                                <span class="fs-6">@option.Text</span>
                                            </label>
                                        </div>
                                    }
                                </div>

                                <button class="btn btn-primary mt-4 w-100 py-2">Проголосовать</button>

                                @if (Model.CanChangeVote)
                                {
                                    <div class="form-text text-center mt-2">Вы можете изменить свой голос позже.</div>
                                }
                            </form>
                        }
                    }

                    @if (isAuthor)
                    {
                        <hr class="my-4" />
                        <h6 class="text-muted mb-3">Управление опросом</h6>

                        @if (Model.Status == PollStatus.Draft)
                        {
                            <form asp-action="Publish" method="post" class="mb-2">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="btn btn-success w-100">Опубликовать черновик</button>
                            </form>
                        }

                        <div class="d-flex gap-2 mb-2">
                            <a class="btn btn-outline-secondary flex-fill" asp-action="ExportCsv" asp-route-id="@Model.Id">CSV</a>
                            <a class="btn btn-outline-secondary flex-fill" asp-action="ExportXlsx" asp-route-id="@Model.Id">XLSX</a>
                        </div>

                        <form asp-action="Delete" asp-controller="Polls" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Точно удаляем? Это действие необратимо.');">
                            <button type="submit" class="btn btn-outline-danger w-100">Удалить опрос</button>
                        </form>
                    }
                </div>

                @if (Model.Attachments != null && Model.Attachments.Any())
                {
                    <div class="card-footer bg-white p-4 border-top">
                        <h6 class="fw-bold mb-3 text-secondary">Прикрепленные файлы</h6>
                        <div class="list-group list-group-flush">
                            @foreach (var file in Model.Attachments)
                            {
                                <a href="@file.FilePath" target="_blank" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                                    <div class="text-truncate pe-3">
                                        📄 @file.OriginalFileName
                                    </div>
                                    <span class="badge bg-light text-dark border">@(Math.Round((double)file.FileSize / 1024, 1)) KB</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm oh-card h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h2 class="h5 mb-0 fw-bold">Результаты</h2>
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">🔴 В реальном времени</span>
                    </div>

                    <div class="vstack gap-4 mb-5">
                        @foreach (var option in Model.Options)
                        {
                            var count = Model.Votes.Count(v => v.Selections.Any(s => s.PollOptionId == option.Id));
                            var pct = total == 0 ? 0 : count * 100.0 / total;

                            <div class="d-flex align-items-center">
                                @if (!string.IsNullOrEmpty(option.ImagePath))
                                {
                                    <img src="@option.ImagePath" class="rounded me-3 border" style="width: 48px; height: 48px; object-fit: cover;" alt="Фото" />
                                }
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="fw-medium">@option.Text</span>
                                        <span class="text-secondary fw-bold" id="stat-text-@option.Id">@count ( @pct.ToString("F1")% )</span>
                                    </div>
                                    <div class="progress" style="height: 8px;" role="progressbar" aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                        <div class="progress-bar bg-primary" id="stat-bar-@option.Id" style="width: @pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="oh-chart-wrap p-3 border rounded bg-light">
                        <canvas id="chart" height="150"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/poll-details.js"></script>
    <script>
        initPollDetails(
            '@Model.Id',
            [@Html.Raw(string.Join(',', Model.Options.Select(o => $"'{o.Text.Replace("'", "\\'")}'")))],
            [@string.Join(',', Model.Options.Select(o => Model.Votes.Count(v => v.Selections.Any(s => s.PollOptionId == o.Id))))]
        );
    </script>
}