@model OpinionHub.Web.Models.Admin.AdminIndexVm

@{
    ViewData["Title"] = "Админка";
}

<h2 class="mb-3">Админка — пользователи</h2>

@if (TempData["AdminMessage"] is string ok && !string.IsNullOrWhiteSpace(ok))
{
    <div class="alert alert-success">@ok</div>
}
@if (TempData["AdminError"] is string err && !string.IsNullOrWhiteSpace(err))
{
    <div class="alert alert-danger" style="white-space:pre-line">@err</div>
}

<div class="d-flex gap-2 mb-3">
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <input class="form-control" style="max-width: 360px" name="q" value="@Model.Query" placeholder="Поиск по логину/email" />
        <button class="btn btn-outline-secondary" type="submit">Найти</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Сброс</a>
    </form>
    <div class="flex-grow-1"></div>
    <a class="btn btn-primary" asp-action="Create">Создать пользователя</a>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
        <tr>
            <th>Логин</th>
            <th>Email</th>
            <th>Роли</th>
            <th>Блокировка</th>
            <th style="width: 360px">Действия</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var u in Model.Users)
        {
            <tr>
                <td>
                    <div>@u.UserName</div>
                    <div class="text-muted" style="font-size: 0.85rem">@u.Id</div>
                </td>
                <td>@(u.Email ?? "—")</td>
                <td>
                    @if (u.Roles.Count == 0)
                    {
                        <span class="text-muted">—</span>
                    }
                    else
                    {
                        <span>@string.Join(", ", u.Roles)</span>
                    }
                </td>
                <td>
                    @if (u.IsLockedOut)
                    {
                        <span class="badge bg-danger">заблокирован</span>
                        <div class="text-muted" style="font-size: 0.85rem">
                            до: @(u.LockoutEndUtc?.ToString("u") ?? "?")
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-success">нет</span>
                    }
                </td>
                <td>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Изменить</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="ResetPassword" asp-route-id="@u.Id">Сменить пароль</a>
                        @if (u.IsLockedOut)
                        {
                            <form asp-action="Unlock" asp-route-id="@u.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-success" type="submit">Снять блок</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-warning" asp-action="Lockout" asp-route-id="@u.Id">Блокировать</a>
                        }
                        <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить пользователя @u.UserName?');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Удалить</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
