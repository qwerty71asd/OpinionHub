@model OpinionHub.Web.Models.Admin.AdminIndexVm

@{
    ViewData["Title"] = "Управление пользователями";
}

<div class="oh-hero py-4 py-md-5 mb-4">
    <div class="container">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
            <div>
                <h1 class="display-6 mb-1">Панель администратора</h1>
                <p class="text-secondary mb-0">Управление пользователями, ролями и блокировками.</p>
            </div>
            <a class="btn btn-primary shadow-sm" asp-action="Create">+ Создать пользователя</a>
        </div>
    </div>
</div>

<div class="container pb-5">
    @if (TempData["AdminMessage"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="alert alert-success shadow-sm">@ok</div>
    }
    @if (TempData["AdminError"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-danger shadow-sm" style="white-space:pre-line">@err</div>
    }

    <div class="card border-0 shadow-sm oh-card">
        <div class="card-header bg-white border-bottom p-4 d-flex flex-wrap gap-3 align-items-center justify-content-between">
            <h5 class="mb-0 fw-bold">Список пользователей</h5>

            <form method="get" asp-action="Index" class="d-flex gap-2">
                <input class="form-control bg-light border-0" style="width: 250px;" name="q" value="@Model.Query" placeholder="Поиск по логину/email..." />
                <button class="btn btn-secondary" type="submit">Найти</button>
                @if (!string.IsNullOrEmpty(Model.Query))
                {
                    <a class="btn btn-outline-secondary" asp-action="Index" title="Сбросить поиск">✕</a>
                }
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th class="ps-4">Пользователь</th>
                            <th>Email</th>
                            <th>Роли</th>
                            <th>Статус</th>
                            <th class="text-end pe-4" style="width: 320px">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.Users)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="fw-bold text-dark">@u.UserName</div>
                                    <div class="text-muted font-monospace" style="font-size: 0.75rem">@u.Id</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(u.Email))
                                    {
                                        <a href="mailto:@u.Email" class="text-decoration-none">@u.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (u.Roles.Count == 0)
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                    else
                                    {
                                        @foreach (var role in u.Roles)
                                        {
                                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary-subtle me-1">@role</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (u.IsLockedOut)
                                    {
                                        <span class="badge bg-danger">Заблокирован</span>
                                        <div class="text-muted mt-1" style="font-size: 0.75rem">
                                            до: @(u.LockoutEndUtc?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "навсегда")
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle">Активен</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex flex-wrap justify-content-end gap-2">
                                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@u.Id">Изменить</a>
                                        <a class="btn btn-sm btn-outline-secondary" asp-action="ResetPassword" asp-route-id="@u.Id">Пароль</a>

                                        @if (u.IsLockedOut)
                                        {
                                            <form asp-action="Unlock" asp-route-id="@u.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button class="btn btn-sm btn-success" type="submit" title="Снять блокировку">Разбан</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <a class="btn btn-sm btn-warning" asp-action="Lockout" asp-route-id="@u.Id">Бан</a>
                                        }

                                        <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить пользователя @u.UserName? Это приведет к удалению всех его данных.');">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-danger" type="submit">✕</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Users.Count == 0)
        {
            <div class="card-body text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-2"></i>
                <p class="mb-0">Пользователи не найдены.</p>
            </div>
        }
    </div>
</div>