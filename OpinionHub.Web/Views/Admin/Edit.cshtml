@model OpinionHub.Web.Models.Admin.AdminUserEditVm

@{
    ViewData["Title"] = "Изменить пользователя";
}

<h2 class="mb-3">Изменить пользователя</h2>

<form method="post" class="row g-3" style="max-width: 900px;">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="col-12">
        <div asp-validation-summary="All" class="text-danger"></div>
    </div>

    <div class="col-md-6">
        <label asp-for="UserName" class="form-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
    </div>

    <div class="col-md-6 d-flex align-items-end">
        <div class="form-check">
            <input asp-for="EmailConfirmed" class="form-check-input" />
            <label asp-for="EmailConfirmed" class="form-check-label"></label>
        </div>
    </div>

    <div class="col-12">
        <label class="form-label">Роли</label>
        <div class="d-flex flex-wrap gap-3">
            @foreach (var r in Model.AvailableRoles)
            {
                var checkedNow = Model.SelectedRoles.Contains(r);
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@r" @(checkedNow ? "checked" : "") />
                    <label class="form-check-label">@r</label>
                </div>
            }
        </div>
    </div>

    <div class="col-12">
        <div class="alert alert-secondary mb-0">
            <div><b>LockoutEnd (UTC)</b>: @(Model.LockoutEndUtc?.ToString("u") ?? "—")</div>
            <div class="text-muted" style="font-size: 0.9rem">Если хочешь блокировать/разблокировать — используй кнопки в списке пользователей.</div>
        </div>
    </div>

    <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </div>
</form>
